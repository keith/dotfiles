#!/bin/bash

set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: ldd <binary>" >&2
  exit 1
fi

has_multiple=0
if [[ $# -gt 1 ]]; then
  has_multiple=1
fi

for binary in "$@"; do
  if [[ ! -f "$binary" ]]; then
    echo "ldd: $binary: No such file" >&2
    exit 1
  fi

  if [[ "$has_multiple" -eq 1 ]]; then
    echo "$binary:"
  fi

  if [[ -x /usr/bin/ldd ]]; then
    /usr/bin/ldd "$binary"
    continue
  fi

  magic=$(xxd -p -l 4 "$binary")
  case "$magic" in
    cffaedfe|feedface|feedfacf|cafebabe)
      otool -L "$binary"
      ;;
    7f454c46)
      llvm readelf -d "$binary" | grep NEEDED
      ;;
    *)
      echo "ldd: $binary: unknown binary format" >&2
      exit 1
      ;;
  esac
done
