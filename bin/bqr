#!/usr/bin/env bash

# Dispatched by basename: bqg (query), bqr (run), bqt (test), bqb (build).
# bqg, bqt, bqb are symlinks to this file.

set -euo pipefail

cmd=$(basename "$0")

names=()
flags=()
rest=()
seen_dashdash=0
for arg in "$@"; do
  if (( seen_dashdash )); then
    rest+=("$arg")
  elif [[ $arg == -- ]]; then
    seen_dashdash=1
    rest+=("$arg")
  elif [[ $arg == -* ]]; then
    flags+=("$arg")
  else
    names+=("$arg")
  fi
done

if [[ ${#names[@]} -eq 0 ]]; then
  echo "error: at least one target name is required" >&2
  exit 1
fi

# Anything with / or : is a label or target pattern that bazel can consume
# directly. Bare names are resolved through attr(name, ...) via bazel query.
labels=()
name_parts=()
for name in "${names[@]}"; do
  if [[ $name == */* || $name == *:* ]]; then
    labels+=("$name")
  else
    name_parts+=("attr(name, '$name', ...)")
  fi
done

query=""
if [[ ${#name_parts[@]} -gt 0 ]]; then
  for part in "${name_parts[@]}"; do
    [[ -n $query ]] && query+=" + "
    query+="$part"
  done
fi

if [[ ${#labels[@]} -gt 0 ]]; then
  [[ -n $query ]] && query+=" + "
  query+="set(${labels[*]})"
fi

if [[ "$cmd" == bqg ]]; then
  exec bazel query "$query" ${flags[@]+"${flags[@]}"}
fi

patterns=$(mktemp)
bazel query "$query" > "$patterns"

if [[ ! -s $patterns ]]; then
  echo "error: no targets matching: ${names[*]}" >&2
  exit 1
fi

targets=()
while IFS= read -r line || [[ -n $line ]]; do
  [[ -n $line ]] && targets+=("$line")
done < "$patterns"

count=${#targets[@]}

case "$cmd" in
  bqr)
    if [[ $count -ne 1 ]]; then
      target=$(printf '%s\n' "${targets[@]}" | fzf)
    else
      target=${targets[0]}
    fi
    set -x
    exec bazel run ${flags[@]+"${flags[@]}"} "$target" -- ${rest[@]+"${rest[@]}"}
    ;;
  bqt)
    if [[ $count -gt 5 ]]; then
      echo "note: more than one target matches: ${names[*]}"
      echo
      printf '%s\n' "${targets[@]}"
      echo
      echo -n 'Do you want to test all of them? [Y/n] '
      read -r answer
      if [[ "$answer" != "Y" && "$answer" != "y" && "$answer" != "" ]]; then
        exit 1
      fi
    fi

    set -x
    exec bazel test ${flags[@]+"${flags[@]}"} ${rest[@]+"${rest[@]}"} "${targets[@]}"
    ;;
  bqb)
    set -x
    exec bazel build ${flags[@]+"${flags[@]}"} ${rest[@]+"${rest[@]}"} "${targets[@]}"
    ;;
  *)
    echo "error: $cmd: unknown invocation name (expected bqg, bqr, bqt, or bqb)" >&2
    exit 1
    ;;
esac
