#!/usr/bin/env bash

set -euo pipefail

only=all
if [[ $# -gt 0 ]]; then
  only="$1"
fi

installed=0

if [[ "$only" == "all" || "$only" == "metals" ]]; then
  # For https://metals-lsp.org/neovim
  brew install coursier/formulas/coursier
  installed=1
fi

if [[ "$only" == "all" || "$only" == "bazelrc-lsp" ]]; then
  cargo install --git https://github.com/salesforce-misc/bazelrc-lsp --force
  installed=1
fi

if [[ "$only" == "all" || "$only" == "ty" ]]; then
  cargo install --git https://github.com/astral-sh/ruff ty --locked --force
  installed=1
fi

if [[ "$only" == "all" || "$only" == "starpls" ]]; then
  starpls_dir="$HOME/dev/starpls"
  if [[ -d "$starpls_dir" ]]; then
    cargo +nightly-2023-12-06 install --path "$starpls_dir/crates/starpls" starpls --locked --force
  else
    cargo +nightly-2023-12-06 install --git https://github.com/withered-magic/starpls starpls --locked --force
  fi
  installed=1
fi

if [[ $installed -eq 0 ]]; then
  echo "error: unknown LSP: $only"
  exit 1
fi
