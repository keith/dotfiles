#!/usr/bin/env bash

set -euo pipefail

# For https://metals-lsp.org/neovim
brew install coursier/formulas/coursier

cargo install --git https://github.com/salesforce-misc/bazelrc-lsp
cargo install --git https://github.com/astral-sh/ruff ty --locked

starpls_dir="$HOME/dev/starpls"
if [[ -d "$starpls_dir" ]]; then
  cargo +nightly-2023-12-06 install --git "file://$starpls_dir" starpls --locked
else
  cargo +nightly-2023-12-06 install --git https://github.com/withered-magic/starpls starpls --locked
fi
