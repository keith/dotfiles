#!/usr/bin/env python3

import argparse
from datetime import datetime, timezone
import json
import re
import subprocess
import sys
from typing import Any


PER_PAGE = 100
BLUE = "\033[34m"
RED = "\033[31m"
YELLOW = "\033[33m"
RESET = "\033[0m"
OSC8_END = "\033]8;;\033\\"


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="List branch commits that have no GitHub commit comments."
    )
    parser.add_argument(
        "-r",
        "--repo",
        help=(
            "GitHub repository, like 'owner/repo' or "
            "'https://github.com/owner/repo'. Defaults to the local git remote."
        ),
    )
    parser.add_argument(
        "-b",
        "--branch",
        required=True,
        help="Branch name to inspect.",
    )
    parser.add_argument(
        "--oldest",
        dest="oldest_commit",
        required=True,
        help="Oldest commit SHA/prefix to include before stopping.",
    )
    return parser


def _repo_from_string(repo: str) -> str | None:
    repo = repo.strip().rstrip("/").removesuffix(".git")
    if re.match(r"^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$", repo):
        return repo

    for pattern in (
        r"^(?:https://)?github\.com[:/](?P<repo>[^/]+/[^/]+)$",
        r"^git@github\.com:(?P<repo>[^/]+/[^/]+)$",
        r"^ssh://git@github\.com/(?P<repo>[^/]+/[^/]+)$",
    ):
        match = re.match(pattern, repo)
        if match:
            return match.group("repo")

    return None


def _normalize_repo(repo: str) -> str:
    normalized = _repo_from_string(repo)
    if not normalized:
        raise SystemExit(
            "error: repo must be in 'owner/repo' format or be a github.com repo URL"
        )
    return normalized


def _run_git(args: list[str]) -> str | None:
    try:
        result = subprocess.run(
            ["git", *args],
            text=True,
            check=False,
            capture_output=True,
        )
    except FileNotFoundError:
        return None

    if result.returncode != 0:
        return None
    output = result.stdout.strip()
    return output or None


def _remote_url(remote: str) -> str | None:
    return _run_git(["remote", "get-url", remote])


def _infer_repo_from_git_remote() -> str:
    upstream = _run_git(
        ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"]
    )
    if upstream and "/" in upstream:
        upstream_url = _remote_url(upstream.split("/", 1)[0])
        if upstream_url and (repo := _repo_from_string(upstream_url)):
            return repo

    origin_url = _remote_url("origin")
    if origin_url and (repo := _repo_from_string(origin_url)):
        return repo

    remotes = _run_git(["remote", "-v"])
    if remotes:
        for line in remotes.splitlines():
            parts = line.split()
            if len(parts) >= 2 and (repo := _repo_from_string(parts[1])):
                return repo

    raise SystemExit(
        "error: could not infer GitHub repo from local git remotes; pass --repo"
    )


def _run_gh_api(repo: str, branch: str, page: int) -> list[dict[str, Any]]:
    result = subprocess.run(
        [
            "gh",
            "api",
            "--method",
            "GET",
            f"repos/{repo}/commits",
            "-f",
            f"sha={branch}",
            "-f",
            f"per_page={PER_PAGE}",
            "-f",
            f"page={page}",
        ],
        text=True,
        check=False,
        capture_output=True,
    )
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
        raise SystemExit(result.returncode)

    return json.loads(result.stdout)


def _parse_github_date(value: str) -> datetime:
    return datetime.fromisoformat(value.replace("Z", "+00:00"))


def _format_relative_date(value: str, now: datetime) -> str:
    commit_date = _parse_github_date(value)
    delta = now - commit_date
    future = delta.total_seconds() < 0
    seconds = abs(int(delta.total_seconds()))

    if seconds < 45:
        return "just now"

    units = (
        ("year", 365 * 24 * 60 * 60),
        ("month", 30 * 24 * 60 * 60),
        ("week", 7 * 24 * 60 * 60),
        ("day", 24 * 60 * 60),
        ("hour", 60 * 60),
        ("minute", 60),
    )
    for name, unit_seconds in units:
        count = seconds // unit_seconds
        if count:
            label = name if count == 1 else f"{name}s"
            if future:
                return f"in {count} {label}"
            return f"{count} {label} ago"

    return "just now"


def _subject(message: str) -> str:
    first_line = message.splitlines()[0] if message else "(no commit message)"
    return first_line.replace("\t", " ")


def _author(commit: dict[str, Any]) -> str:
    commit_author = commit["commit"].get("author") or {}
    github_author = commit.get("author") or {}

    login = github_author.get("login")
    if login:
        return f"@{login}"
    return commit_author.get("name") or "unknown"


def _short_sha(commit: dict[str, Any]) -> str:
    return commit["sha"][:12]


def _osc8(url: str | None, text: str) -> str:
    if not url:
        return text
    return f"\033]8;;{url}\033\\{text}{OSC8_END}"


def _colored_short_sha(commit: dict[str, Any]) -> str:
    return _osc8(commit.get("html_url"), f"{BLUE}{_short_sha(commit)}{RESET}")


def _colored_author(commit: dict[str, Any]) -> str:
    return f"{YELLOW}({_author(commit)}){RESET}"


def _date(commit: dict[str, Any]) -> str | None:
    commit_data = commit["commit"]
    return (commit_data.get("author") or commit_data.get("committer") or {}).get("date")


def _commit_display(commit: dict[str, Any], now: datetime) -> str:
    commit_data = commit["commit"]
    date = _date(commit)
    relative_date = _format_relative_date(date, now) if date else "unknown"
    return "{} {} {} {}".format(
        _colored_short_sha(commit),
        _subject(commit_data.get("message", "")),
        _colored_author(commit),
        relative_date,
    )


def _print_commit(commit: dict[str, Any], now: datetime) -> None:
    print(_commit_display(commit, now))


def _comment_range(commits: list[dict[str, Any]]) -> str:
    if len(commits) == 1:
        return _colored_short_sha(commits[0])
    return f"{_colored_short_sha(commits[0])}..{_colored_short_sha(commits[-1])}"


def _print_comment_chunk(commits: list[dict[str, Any]]) -> None:
    if not commits:
        return

    commit_label = "commit" if len(commits) == 1 else "commits"
    print(
        "{}# commented chunk:{} {} {} with comments: {}".format(
            RED,
            RESET,
            len(commits),
            commit_label,
            _comment_range(commits),
        )
    )


def _comment_count(commit: dict[str, Any]) -> int:
    return commit["commit"].get("comment_count", 0)


def _commits_through_oldest(
    repo: str, branch: str, oldest: str
) -> list[dict[str, Any]]:
    page = 1
    commits: list[dict[str, Any]] = []

    while True:
        page_commits = _run_gh_api(repo, branch, page)
        if not page_commits:
            raise SystemExit(
                f"error: oldest commit not found on {repo}@{branch}: {oldest}"
            )

        for commit in page_commits:
            commits.append(commit)
            if commit["sha"].startswith(oldest):
                return commits

        if len(page_commits) < PER_PAGE:
            raise SystemExit(
                f"error: oldest commit not found on {repo}@{branch}: {oldest}"
            )

        page += 1


def _print_newer_oldest_hint(
    commits: list[dict[str, Any]], comment_chunk: list[dict[str, Any]]
) -> None:
    if not comment_chunk:
        return

    comment_start_index = len(commits) - len(comment_chunk)
    if comment_start_index == 0:
        replacement = commits[0]
    else:
        replacement = commits[comment_start_index - 1]

    if replacement["sha"] == commits[-1]["sha"]:
        return

    skipped = len(comment_chunk)
    commit_label = "commit" if skipped == 1 else "commits"
    print(
        "{}# oldest hint:{} the oldest {} {} all have comments; "
        "use {} as oldest for the same uncommented commits".format(
            RED,
            RESET,
            skipped,
            commit_label,
            _colored_short_sha(replacement),
        )
    )


def _print_oldest_commented_chunk(commits: list[dict[str, Any]]) -> None:
    oldest_commented_index = next(
        (
            index
            for index in range(len(commits) - 1, -1, -1)
            if _comment_count(commits[index]) > 0
        ),
        None,
    )
    if oldest_commented_index is None:
        return

    start = oldest_commented_index
    while start > 0 and _comment_count(commits[start - 1]) > 0:
        start -= 1

    end = oldest_commented_index
    while end + 1 < len(commits) and _comment_count(commits[end + 1]) > 0:
        end += 1

    chunk = commits[start : end + 1]
    commit_label = "commit" if len(chunk) == 1 else "commits"
    print(
        "{}# oldest commented chunk:{} {} {} with comments: {}".format(
            RED,
            RESET,
            len(chunk),
            commit_label,
            _comment_range(chunk),
        )
    )


def _main() -> None:
    parser = _build_parser()
    args = parser.parse_args()
    repo = _normalize_repo(args.repo) if args.repo else _infer_repo_from_git_remote()

    now = datetime.now(tz=timezone.utc)
    comment_chunk: list[dict[str, Any]] = []
    commits = _commits_through_oldest(repo, args.branch, args.oldest_commit)
    for commit in commits:
        if _comment_count(commit) > 0:
            comment_chunk.append(commit)
            continue

        _print_comment_chunk(comment_chunk)
        comment_chunk = []
        _print_commit(commit, now)

    _print_comment_chunk(comment_chunk)
    _print_oldest_commented_chunk(commits)
    _print_newer_oldest_hint(commits, comment_chunk)


if __name__ == "__main__":
    _main()
