#!/usr/bin/env python3

import re
import subprocess
import sys
from urllib.parse import urlparse


SHA_RE = re.compile(rb"(?<![0-9A-Za-z])([0-9A-Fa-f]{7,40})(?![0-9A-Za-z])")
OSC8_START = b"\033]8;;"
OSC8_END = b"\033]8;;\033\\"
OSC8_ST = b"\033\\"


def _git(args: list[str]) -> str:
    return subprocess.check_output(
        ["git", *args],
        stderr=subprocess.DEVNULL,
        text=True,
    ).strip()


def _current_remote() -> str:
    try:
        upstream = _git(
            ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"]
        )
        return upstream.split("/", 1)[0]
    except subprocess.CalledProcessError:
        return "origin"


def _repository_url(remote_url: str) -> str:
    if "://" not in remote_url and ":" in remote_url:
        host, path = remote_url.split(":", 1)
        host = host.rsplit("@", 1)[-1]
    else:
        parsed = urlparse(remote_url)
        host = parsed.hostname
        path = parsed.path.lstrip("/")

    if not host or not path:
        raise ValueError(f"could not parse remote URL: {remote_url}")

    path = path.rstrip("/")
    if path.endswith(".git"):
        path = path[:-4]

    parts = path.split("/")
    if len(parts) < 2:
        raise ValueError(f"could not parse repository from remote URL: {remote_url}")

    owner, repo = parts[:2]
    return f"https://{host}/{owner}/{repo}"


def _full_sha(short_sha: bytes, cache: dict[bytes, bytes | None]) -> bytes | None:
    if short_sha in cache:
        return cache[short_sha]

    sha_text = short_sha.decode("ascii")
    if len(sha_text) == 40:
        cache[short_sha] = short_sha
        return short_sha

    try:
        full_sha = _git(["rev-parse", "--verify", f"{sha_text}^{{commit}}"]).encode()
    except subprocess.CalledProcessError:
        cache[short_sha] = None
        return None

    cache[short_sha] = full_sha
    return full_sha


def _linkify(
    commit_base_url: bytes, line: bytes, full_sha_cache: dict[bytes, bytes | None]
) -> bytes:
    def replace(match: re.Match[bytes]) -> bytes:
        sha = match.group(1)
        full_sha = _full_sha(sha, full_sha_cache)
        if full_sha is None:
            return sha

        url = commit_base_url + b"/" + full_sha
        return OSC8_START + url + OSC8_ST + sha + OSC8_END

    return SHA_RE.sub(replace, line)


def _main() -> None:
    remote = _current_remote()
    remote_url = _git(["remote", "get-url", remote])
    commit_base_url = (_repository_url(remote_url) + "/commit").encode()
    full_sha_cache: dict[bytes, bytes | None] = {}

    for line in sys.stdin.buffer:
        sys.stdout.buffer.write(_linkify(commit_base_url, line, full_sha_cache))


if __name__ == "__main__":
    _main()
