#!/usr/bin/env bash

set -euo pipefail

active_window="$(hyprctl -j activewindow)"
active_class="$(jq -r '.class // empty' <<<"$active_window")"
active_initial_class="$(jq -r '.initialClass // empty' <<<"$active_window")"

if [[ -z "$active_class" && -z "$active_initial_class" ]]; then
  exit 0
fi

lookup_names=()
for name in "$active_class" "$active_initial_class"; do
  [[ -n "$name" ]] || continue
  lookup_names+=("$name" "${name,,}")
done

case "${active_class,,}" in
  alacritty)
    exec alacritty
    ;;
  org.wezfurlong.wezterm | wezterm)
    exec wezterm
    ;;
  kitty)
    exec kitty
    ;;
  firefox | org.mozilla.firefox)
    exec firefox --new-window
    ;;
  google-chrome | chromium | brave-browser)
    exec "${active_class,,}" --new-window
    ;;
esac

desktop_dirs=(
  "$HOME/.local/share/applications"
  "/usr/local/share/applications"
  "/usr/share/applications"
)

desktop_file=""
for name in "${lookup_names[@]}"; do
  for dir in "${desktop_dirs[@]}"; do
    for candidate in "$dir/$name.desktop" "$dir/${name}.Desktop"; do
      if [[ -f "$candidate" ]]; then
        desktop_file="$candidate"
        break 3
      fi
    done
  done
done

if [[ -z "$desktop_file" ]]; then
  for dir in "${desktop_dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r -d '' candidate; do
      wm_class="$(awk -F= 'tolower($1) == "startupwmclass" { print tolower($2); exit }' "$candidate")"
      for name in "${lookup_names[@]}"; do
        if [[ "$wm_class" == "${name,,}" ]]; then
          desktop_file="$candidate"
          break 3
        fi
      done
    done < <(find "$dir" -maxdepth 1 -type f -name '*.desktop' -print0)
  done
fi

if [[ -z "$desktop_file" ]]; then
  echo "error: could not find .desktop file for class '$active_class'" >&2
  exit 1
fi

desktop_id="${desktop_file##*/}"
desktop_id="${desktop_id%.desktop}"
exec gtk-launch "$desktop_id"
