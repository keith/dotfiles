#!/bin/bash

set -euo pipefail

readonly name=$1
shift

patterns=$(mktemp)

bqg "$name" > "$patterns"

if [[ ! -s $patterns ]]; then
  echo "error: no tests matching '$name'" >&2
  exit 1
fi

count=$(wc -l < "$patterns")
if [[ $count -gt 5 ]]; then
  echo "note: more than one test matches '$name':"
  echo
  cat "$patterns"

  echo
  echo -n "Do you want to run all of them? [Y/n] "
  read -r answer
  if [[ "$answer" != "Y" && "$answer" != "y" && "$answer" != "" ]]; then
    exit 1
  fi
fi

if [[ $count -eq 1 ]]; then
  args=("$(cat "$patterns")")
else
  args=(--target_pattern_file="$patterns")
fi

set -x
bazel test "$@" "${args[@]}"
