#!/bin/bash

set -euo pipefail

name=$(basename "$0")
executable=$(which -a "$name" | sed -n '2p')
if [[ -x "$executable" ]]; then
  exec "$executable" "$@"
fi

brew_path=$(brew --prefix clang-format 2>/dev/null || true)
if [[ -x "$brew_path/bin/$name" ]]; then
  exec "$brew_path/bin/$name" "$@"
fi

exec llvm "$name" "$@"
